}

class RemoveWebsiteIndexOperation {
    -{static} Log logger
    -Weblog website
    -Weblogger roller
    
    +RemoveWebsiteIndexOperation(Weblogger roller, LuceneIndexManager mgr, Weblog website)
    +void doRun()
